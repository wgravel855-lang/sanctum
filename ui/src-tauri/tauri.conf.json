{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sanctum",
  "version": "0.2.0",
  "identifier": "app.sanctum.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Sanctum",
        "width": 440,
        "height": 800,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": true
      },
      {
        "label": "intervention",
        "url": "index.html#intervention",
        "title": "Sanctum",
        "visible": false,
        "fullscreen": true,
        "alwaysOnTop": true,
        "decorations": false,
        "skipTaskbar": true,
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Sanctum contributors",
    "shortDescription": "Honest adult-content blocker for Windows.",
    "longDescription": "Sanctum filters adult content across every browser via the DNS and hosts layers, keeps working in the background, and can lock its settings for a chosen duration. Friction, not stealth.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/sanctum-service",
      "binaries/sanctum-watchdog",
      "binaries/sanctum-recover"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "installer-hooks.nsh"
      }
    }
  }
}
